# Copy to .env and adjust. docker-compose reads these for both api and db.

# API
PORT=3000

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=miniwallet
DB_PASSWORD=miniwallet
DB_NAME=miniwallet

# Auth (used from Slice 1 onward)
JWT_SECRET=change-me-in-real-deployments
JWT_EXPIRES_IN=3600

# Seed balance granted to each new user (Slice 2)
SEED_BALANCE=5000.00

# Admin bootstrap (Slice 4) — created on boot if it does not exist
ADMIN_EMAIL=admin@miniwallet.local
ADMIN_PASSWORD=admin12345

# Suspicious-transaction detection thresholds (Slice 5, ADR-005)
SUSPICIOUS_VELOCITY_COUNT=5
SUSPICIOUS_VELOCITY_WINDOW_MIN=1
SUSPICIOUS_STRUCTURING_COUNT=2
SUSPICIOUS_STRUCTURING_WINDOW_MIN=10

# Rate limiting (requests per TTL window, per IP)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
